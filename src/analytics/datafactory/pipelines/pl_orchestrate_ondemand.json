{
  "name": "pl_orchestrate_ondemand",
  "properties": {
    "description": "On-demand ingestion for specific tenant and entities. Trigger from ADF Studio, REST API, or CLI.",
    "activities": [
      {
        "name": "Run_Graph_If_Needed",
        "type": "IfCondition",
        "dependsOn": [],
        "typeProperties": {
          "expression": {
            "value": "@or(or(or(or(or(or(or(or(or(or(or(or(or(or(or(or(or(or(contains(pipeline().parameters.entityNames, 'entra_users'), contains(pipeline().parameters.entityNames, 'entra_groups')), contains(pipeline().parameters.entityNames, 'entra_contacts')), contains(pipeline().parameters.entityNames, 'entra_group_members')), contains(pipeline().parameters.entityNames, 'entra_group_owners')), contains(pipeline().parameters.entityNames, 'entra_devices')), contains(pipeline().parameters.entityNames, 'intune_managed_devices')), contains(pipeline().parameters.entityNames, 'entra_applications')), contains(pipeline().parameters.entityNames, 'entra_service_principals')), contains(pipeline().parameters.entityNames, 'entra_delegated_permission_grants')), contains(pipeline().parameters.entityNames, 'entra_sp_assignments')), contains(pipeline().parameters.entityNames, 'entra_sp_owners')), contains(pipeline().parameters.entityNames, 'entra_app_owners')), contains(pipeline().parameters.entityNames, 'entra_application_permission_grants')), contains(pipeline().parameters.entityNames, 'entra_sp_claims_mapping_policies')), contains(pipeline().parameters.entityNames, 'entra_delegated_permission_classifications')), contains(pipeline().parameters.entityNames, 'entra_sign_in_logs')), contains(pipeline().parameters.entityNames, 'entra_app_proxy_config')), contains(pipeline().parameters.entityNames, 'entra_provisioning_jobs'))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Execute_Graph_Job",
              "type": "ExecutePipeline",
              "typeProperties": {
                "pipeline": { "referenceName": "pl_run_container_job", "type": "PipelineReference" },
                "parameters": {
                  "containerJobName": { "value": "@pipeline().parameters.graphJobName", "type": "Expression" },
                  "tenantKey": { "value": "@pipeline().parameters.tenantKey", "type": "Expression" },
                  "scheduleTier": { "value": "@pipeline().parameters.scheduleTier", "type": "Expression" },
                  "keyVaultName": { "value": "@pipeline().parameters.keyVaultName", "type": "Expression" },
                  "storageAccountName": { "value": "@pipeline().parameters.storageAccountName", "type": "Expression" },
                  "maxParallelism": { "value": "@pipeline().parameters.maxParallelism", "type": "Expression" },
                  "resourceGroupName": { "value": "@pipeline().parameters.resourceGroupName", "type": "Expression" },
                  "subscriptionId": { "value": "@pipeline().parameters.subscriptionId", "type": "Expression" }
                },
                "waitOnCompletion": true
              }
            }
          ]
        }
      },
      {
        "name": "Run_EXO_If_Needed",
        "type": "IfCondition",
        "dependsOn": [],
        "typeProperties": {
          "expression": {
            "value": "@or(or(or(or(or(or(contains(pipeline().parameters.entityNames, 'exo_mailboxes'), contains(pipeline().parameters.entityNames, 'exo_contacts')), contains(pipeline().parameters.entityNames, 'exo_mail_users')), contains(pipeline().parameters.entityNames, 'exo_distribution_groups')), contains(pipeline().parameters.entityNames, 'exo_unified_groups')), contains(pipeline().parameters.entityNames, 'exo_group_members')), contains(pipeline().parameters.entityNames, 'exo_mailbox_statistics'))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Execute_EXO_Job",
              "type": "ExecutePipeline",
              "typeProperties": {
                "pipeline": { "referenceName": "pl_run_container_job", "type": "PipelineReference" },
                "parameters": {
                  "containerJobName": { "value": "@pipeline().parameters.exoJobName", "type": "Expression" },
                  "tenantKey": { "value": "@pipeline().parameters.tenantKey", "type": "Expression" },
                  "scheduleTier": { "value": "@pipeline().parameters.scheduleTier", "type": "Expression" },
                  "keyVaultName": { "value": "@pipeline().parameters.keyVaultName", "type": "Expression" },
                  "storageAccountName": { "value": "@pipeline().parameters.storageAccountName", "type": "Expression" },
                  "maxParallelism": { "value": "@pipeline().parameters.maxParallelism", "type": "Expression" },
                  "resourceGroupName": { "value": "@pipeline().parameters.resourceGroupName", "type": "Expression" },
                  "subscriptionId": { "value": "@pipeline().parameters.subscriptionId", "type": "Expression" }
                },
                "waitOnCompletion": true
              }
            }
          ]
        }
      },
      {
        "name": "Run_SPO_If_Needed",
        "type": "IfCondition",
        "dependsOn": [],
        "typeProperties": {
          "expression": {
            "value": "@or(contains(pipeline().parameters.entityNames, 'spo_sites'), contains(pipeline().parameters.entityNames, 'spo_site_permissions'))",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "name": "Execute_SPO_Job",
              "type": "ExecutePipeline",
              "typeProperties": {
                "pipeline": { "referenceName": "pl_run_container_job", "type": "PipelineReference" },
                "parameters": {
                  "containerJobName": { "value": "@pipeline().parameters.spoJobName", "type": "Expression" },
                  "tenantKey": { "value": "@pipeline().parameters.tenantKey", "type": "Expression" },
                  "scheduleTier": { "value": "@pipeline().parameters.scheduleTier", "type": "Expression" },
                  "keyVaultName": { "value": "@pipeline().parameters.keyVaultName", "type": "Expression" },
                  "storageAccountName": { "value": "@pipeline().parameters.storageAccountName", "type": "Expression" },
                  "maxParallelism": { "value": "@pipeline().parameters.maxParallelism", "type": "Expression" },
                  "resourceGroupName": { "value": "@pipeline().parameters.resourceGroupName", "type": "Expression" },
                  "subscriptionId": { "value": "@pipeline().parameters.subscriptionId", "type": "Expression" }
                },
                "waitOnCompletion": true
              }
            }
          ]
        }
      }
    ],
    "parameters": {
      "tenantKey": { "type": "string" },
      "entityNames": { "type": "string", "defaultValue": "entra_users,entra_groups" },
      "scheduleTier": { "type": "string", "defaultValue": "core" },
      "keyVaultName": { "type": "string" },
      "storageAccountName": { "type": "string" },
      "graphJobName": { "type": "string" },
      "exoJobName": { "type": "string" },
      "spoJobName": { "type": "string" },
      "maxParallelism": { "type": "string", "defaultValue": "10" },
      "resourceGroupName": { "type": "string" },
      "subscriptionId": { "type": "string" }
    },
    "variables": {}
  }
